    "bp_management": [
      {
        "id": "bp-chk-001",
        "domain": "bp_management",
        "category": "systolic",
        "condition": "Systolic blood pressure documented",
        "guidance": "BP must be < 185/110 mmHg before IVT. Post-IVT target is < 180/105 for 24 hours.",
        "variables": [
          "sbp"
        ],
        "sourceTable": "Section 4.3"
      },
      {
        "id": "bp-chk-002",
        "domain": "bp_management",
        "category": "diastolic",
