    "evt_eligibility": [
      {
        "id": "evt-chk-001",
        "domain": "evt_eligibility",
        "category": "vessel",
        "condition": "Large vessel occlusion (LVO) identified",
        "guidance": "EVT is indicated for anterior circulation LVO (ICA, M1). CTA or MRA should confirm occlusion site.",
        "variables": [
          "vessel"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-002",
        "domain": "evt_eligibility",
        "category": "circulation",
        "condition": "Anterior vs posterior circulation determined",
        "guidance": "EVT evidence is strongest for anterior circulation (ICA, M1/M2). Posterior circulation (basilar) EVT has different criteria.",
        "variables": [
          "vessel"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-003",
        "domain": "evt_eligibility",
        "category": "time_window",
        "condition": "Time from last known normal established",
        "guidance": "EVT within 6 hours has strongest evidence. Extended window (6-24h) requires perfusion imaging selection.",
        "variables": [
          "timeHours"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-004",
        "domain": "evt_eligibility",
        "category": "imaging",
        "condition": "ASPECTS score obtained",
        "guidance": "ASPECTS >= 6 generally favors EVT. Lower scores may still benefit but with less certainty.",
        "variables": [
          "aspects"
        ],
        "sourceTable": "Section 3.2"
      },
      {
        "id": "evt-chk-005",
        "domain": "evt_eligibility",
        "category": "functional_status",
        "condition": "Pre-stroke functional status (mRS) assessed",
        "guidance": "Pre-stroke mRS 0-2 is generally used for EVT eligibility. Higher mRS requires individualized assessment.",
        "variables": [
          "prestrokeMRS"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-006",
        "domain": "evt_eligibility",
        "category": "age",
        "condition": "Age documented",
        "guidance": "EVT benefits adult patients across age ranges. Pediatric EVT has separate considerations.",
        "variables": [
          "age"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-007",
        "domain": "evt_eligibility",
        "category": "severity",
        "condition": "Stroke severity (NIHSS) documented",
        "guidance": "NIHSS >= 6 generally indicates EVT-level deficit. Lower NIHSS with LVO may still warrant EVT consideration.",
        "variables": [
          "nihss"
        ],
        "sourceTable": "Section 4.7"
      },
      {
        "id": "evt-chk-008",
        "domain": "evt_eligibility",
        "category": "perfusion",
        "condition": "Perfusion imaging for extended window",
        "guidance": "For patients presenting 6-24 hours from last known normal, perfusion imaging (CT perfusion or MRI DWI/PWI) is recommended to identify salvageable tissue.",
        "variables": [
          "penumbra",
          "dwiFlair"
        ],
        "sourceTable": "Section 3.2"
      }
    ],
