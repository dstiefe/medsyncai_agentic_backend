        "variables": [
          "dbp"
        ],
        "sourceTable": "Section 4.3"
      },
      {
        "id": "bp-chk-003",
        "domain": "bp_management",
        "category": "ivt_threshold",
        "condition": "BP eligibility for IVT assessed (< 185/110)",
        "guidance": "Blood pressure must be controlled to < 185/110 mmHg before and during IVT administration. Consider IV labetalol or nicardipine.",
        "variables": [
          "sbp",
          "dbp"
        ],
        "sourceTable": "Table 8"
      }
    ],
