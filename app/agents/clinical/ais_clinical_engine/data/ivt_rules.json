        "var": "extensiveHypodensity",
        "op": "==",
        "val": true
      },
      "guidance": "Extensive regions of obvious hypodensity on computed tomography are an absolute contraindication to IV alteplase.",
      "sourceTable": "Table 8",
      "sourcePage": 0
    },
    {
      "id": "t8-003",
      "tier": "absolute",
      "condition": "Moderate-severe traumatic brain injury within 14 days",
      "trigger": {
        "logic": "AND",
        "clauses": [
