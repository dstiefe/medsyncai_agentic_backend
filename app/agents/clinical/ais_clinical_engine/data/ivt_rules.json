  "table8_rules": [
    {
      "id": "t8-001",
      "tier": "absolute",
      "condition": "CT or MRI evidence of intracranial hemorrhage",
      "trigger": {
        "var": "hemorrhage",
        "op": "==",
        "val": true
      },
      "guidance": "Intracranial hemorrhage on CT or MRI is an absolute contraindication to IV alteplase.",
      "sourceTable": "Table 8",
      "sourcePage": 0
    },
    {
      "id": "t8-002",
      "tier": "absolute",
      "condition": "Extensive regions of obvious hypodensity on CT",
