{
  "metadata": {
    "purpose": "Discrimination index for anchor words. Classifies every anchor term by how many sections it appears in, enabling the two-stage routing pipeline. Stage 1 uses ALL terms (weighted by tier) for section-level co-occurrence scoring. Stage 2 drops global terms for content retrieval.",
    "tiers": {
      "global": "Appears in 5+ sections. Ubiquitous (IVT, EVT, AIS, etc.). Stage 1: participates in co-occurrence scoring (weight 0.5, or 1.5 if primary role). Stage 2: DROPPED from content retrieval.",
      "broad": "Appears in 3-4 sections. Stage 1: participates in scoring (weight 2, or 6 if primary). Stage 2: dropped if pinpoint/narrow terms already identify the section; kept otherwise.",
      "narrow": "Appears in exactly 2 sections. Strong signal. Weight 5 in both stages.",
      "pinpoint": "Appears in exactly 1 section. Strongest signal. Weight 10 in both stages."
    },
    "routing_algorithm": [
      "1. LLM parses query -> extracts anchor terms + intent.",
      "2. Expand terms via synonym_dictionary.v2.json.",
      "3. Classify each matched term by tier using this index.",
      "4. STAGE 1: Score ALL sections. Weights: pinpoint=10, narrow=5, broad=2, global=0.5. Primary role = 3x base.",
      "   Co-occurrence bonus: score *= (1 + 0.3 * (matched_terms - 1)) when 2+ terms match.",
      "5. STAGE 2: Drop global terms. If pinpoint/narrow exist, also drop broad. Search within winning section.",
      "6. All-global queries: primary/mention role breaks ties. If still tied, parsed intent disambiguates."
    ],
    "example_walkthrough": {
      "query": "can I give IVT with SBP 200",
      "matched_terms": {
        "IVT": {
          "tier": "global",
          "sections": "26 sections",
          "stage_1": "participates with weight 0.5",
          "stage_2": "DROPPED"
        },
        "SBP": {
          "tier": "pinpoint",
          "sections": [
            "4.3"
          ],
          "stage_1": "participates with weight 10",
          "stage_2": "KEPT"
        }
      },
      "stage_1_scoring": {
        "section_4.3": "IVT(0.5) + SBP(10) = 10.5 * 1.3 co-occurrence bonus = 13.65",
        "section_4.6.1": "IVT(0.5) = 0.5",
        "winner": "4.3"
      },
      "stage_2": "Drop IVT. Search section 4.3 with: SBP. Result: recs 5 and 7."
    }
  },
