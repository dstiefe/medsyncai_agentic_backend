      "note": "LVO typically means ICA or M1"
    },
    "distal occlusion": {
      "expands_to": ["M2", "M3", "ACA", "PCA"],
      "synonyms": ["medium vessel", "MeVO", "distal"]
    },
    "extended window": {
      "expands_to": ["extended window"],
      "section_hint": "4.6.3",
      "note": "This is a SECTION CONCEPT, not a time range. Routes to 4.6.3. Do NOT convert to time_window_hours."
    },
    "standard window": {
      "expands_to": ["standard window"],
      "section_hint": "4.6.1",
      "note": "Within 4.5 hours. Routes to 4.6.1."
    },
    "late window EVT": {
      "expands_to": ["late window EVT"],
      "section_hint": "4.7.2",
      "note": "EVT 6-24h. Routes to 4.7.2."
    },
    "wake-up stroke": {
      "expands_to": ["wake-up stroke", "unknown onset"],
      "section_hint": "4.6.3"
    },
    "drip-and-ship": {
      "expands_to": ["drip-and-ship", "transfer"],
