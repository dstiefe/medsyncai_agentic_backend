  "qualifier_rules": {
    "_doc": "Qualifiers narrow context WITHIN a section but do NOT change section routing. They pass through to the Assembly LLM.",
    "examples": [
      {
        "question": "What is the BP goal for patients with failed recanalization after EVT?",
        "dominant_topic": "BP goal",
        "routes_to": "4.3",
        "qualifiers": ["failed recanalization", "after EVT"],
        "qualifier_role": "Assembly LLM uses these to identify which BP rec applies and acknowledge when guideline doesn't specifically address this scenario"
      },
      {
        "question": "Is tenecteplase an option for extended-window IVT?",
        "dominant_topic": "extended-window IVT",
        "routes_to": "4.6.3",
        "qualifiers": ["tenecteplase"],
        "qualifier_role": "Assembly LLM emphasizes tenecteplase-specific data within 4.6.3 RSS"
      },
      {
        "question": "What antiplatelet should I use after IVT?",
        "dominant_topic": "antiplatelet",
        "routes_to": "4.8",
        "qualifiers": ["after IVT"],
        "qualifier_role": "Assembly LLM focuses on timing of antiplatelet initiation post-IVT"
      }
    ]
  }
