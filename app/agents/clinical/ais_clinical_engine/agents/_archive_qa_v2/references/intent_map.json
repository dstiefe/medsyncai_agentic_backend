{
  "metadata": {
    "purpose": "Intent Map: expands clinical concepts in user questions into concept groups for deterministic section routing. When the user says 'basilar treatment', the LLM or Python expands that into concept groups, then the section router finds which sections contain ALL concepts in each group.",
    "usage": "1. Extract clinical concepts from question. 2. Look up concept expansions. 3. Build concept groups. 4. For each group, find sections where ALL concepts coexist (using section_variable_matrix.json). 5. Section with most group matches wins.",
    "design_principles": [
      "Section concepts are NOT patient variables — 'extended window' routes to 4.6.3, it is not a time_window value",
      "Clinical variables only come from patient descriptions — '72yo, NIHSS 18, M1 at 10h' has variables",
      "The section IS the filter — once routed, Python pulls everything from that section",
      "Qualifiers narrow context within a section, they do not change section routing"
    ]
  },

  "concept_expansions": {
    "_doc": "Maps a clinical term the user might say to its constituent concepts. The router checks which sections contain ALL expanded concepts.",

    "treatment": {
      "expands_to": ["IVT", "EVT"],
      "note": "Treatment for stroke = IVT and/or EVT depending on context"
    },
    "reperfusion": {
      "expands_to": ["IVT", "EVT"],
      "note": "Reperfusion therapy encompasses both IVT and EVT"
    },
    "thrombolysis": {
      "expands_to": ["IVT"],
      "synonyms": ["tPA", "lytic", "thrombolytic", "fibrinolytic", "clot buster"]
    },
    "thrombectomy": {
      "expands_to": ["EVT"],
      "synonyms": ["mechanical thrombectomy", "endovascular", "stent retriever", "aspiration"]
    },
    "tenecteplase": {
      "expands_to": ["tenecteplase"],
      "synonyms": ["TNK", "TNKase"],
      "note": "Specific IVT drug — routes to 4.6.2 (within 4.5h) or 4.6.3 (extended window) depending on context"
    },
    "alteplase": {
      "expands_to": ["alteplase"],
      "synonyms": ["tPA", "rt-PA", "Activase"],
      "note": "Standard IVT drug"
    },
    "basilar": {
      "expands_to": ["basilar", "posterior"],
      "synonyms": ["posterior circulation", "vertebrobasilar", "vertebral"],
      "section_hint": "4.7.3"
    },
    "anterior": {
      "expands_to": ["anterior", "ICA", "M1", "MCA"],
      "synonyms": ["anterior circulation", "carotid territory"]
    },
    "LVO": {
      "expands_to": ["LVO", "ICA", "M1"],
