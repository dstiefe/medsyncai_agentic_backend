  "concept_groups": {
    "_doc": "Pre-built concept groups for common multi-concept queries. Each group maps to the section(s) where ALL concepts coexist. Python checks actual content to confirm.",

    "basilar_treatment": {
      "question_patterns": ["treatment for basilar", "basilar stroke treatment", "what to do for basilar"],
      "groups": [
        {"concepts": ["EVT", "basilar"], "expected_sections": ["4.7.3"]},
        {"concepts": ["IVT", "basilar"], "expected_sections": ["4.6.3"]}
      ]
    },
    "basilar_mRS": {
      "question_patterns": ["mRS for basilar", "mRS criteria basilar EVT"],
