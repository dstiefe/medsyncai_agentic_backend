{
  "metadata": {
    "purpose": "Section-Variable Matrix: which sections contain which clinical variables in their recommendation text. Used by the deterministic section router to find sections where ALL query concepts coexist.",
    "usage": "Given a question's extracted concepts (e.g., ['BP', 'EVT', 'recanalization']), find sections where ALL concepts appear. The section with the most concept overlap wins.",
    "source": "Extracted from guideline_knowledge.json recommendation text and RSS content.",
    "variable_types": {
      "intervention": "Treatment type (IVT, EVT, drug names)",
      "time_window": "Hours/minutes from symptom onset",
      "vessel": "Occluded vessel (ICA, M1, M2, basilar, etc.)",
      "circulation": "Anterior vs posterior/basilar",
      "NIHSS": "NIH Stroke Scale score",
      "ASPECTS": "Alberta Stroke Program Early CT Score (anterior)",
      "PC_ASPECTS": "Posterior circulation ASPECTS",
      "age": "Patient age thresholds",
      "premorbid_mRS": "Pre-stroke modified Rankin Scale",
      "BP": "Blood pressure values (systolic/diastolic)",
      "core_volume": "Ischemic core volume in mL",
      "drug_dose": "Specific medication doses",
      "SpO2": "Oxygen saturation targets",
      "glucose": "Blood glucose thresholds",
      "temperature": "Temperature targets",
      "imaging": "Imaging modalities (CT, CTA, MRI, etc.)",
      "TICI": "Reperfusion grades",
      "categorical": "Non-numeric criteria (disabling, mild, wake-up stroke, etc.)"
    }
  },
